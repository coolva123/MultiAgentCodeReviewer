+import os
+import sqlite3
+import pickle
+import subprocess
+from flask import Flask, request, jsonify
+
+app = Flask(__name__)
+
+# Database config hardcoded
+DB_PASSWORD = "admin123"
+DB_HOST = "prod-db.internal"
+AWS_SECRET_KEY = "wJalrXUtnFEMI/K7MDENG/bPxRfiCYEXAMPLEKEY"
+
+def get_db():
+    return sqlite3.connect(f"host={DB_HOST} password={DB_PASSWORD}")
+
+@app.route("/search")
+def search():
+    keyword = request.args.get("q", "")
+    conn = sqlite3.connect("app.db")
+    cursor = conn.cursor()
+    # Direct string concat — SQL injection
+    query = "SELECT * FROM products WHERE name = '" + keyword + "'"
+    cursor.execute(query)
+    rows = cursor.fetchall()
+    return jsonify(rows)
+
+@app.route("/user/<user_id>")
+def get_user(user_id):
+    conn = sqlite3.connect("app.db")
+    cursor = conn.cursor()
+    # f-string SQL injection
+    cursor.execute(f"SELECT * FROM users WHERE id = {user_id}")
+    row = cursor.fetchone()
+    return jsonify(row)
+
+@app.route("/run", methods=["POST"])
+def run_command():
+    cmd = request.json.get("cmd", "")
+    # Command injection
+    result = subprocess.run(cmd, shell=True, capture_output=True, text=True)
+    return jsonify({"output": result.stdout})
+
+@app.route("/load", methods=["POST"])
+def load_object():
+    data = request.data
+    # Insecure deserialization
+    obj = pickle.loads(data)
+    return jsonify({"status": "loaded", "type": str(type(obj))})
+
+@app.route("/eval", methods=["POST"])
+def evaluate():
+    expr = request.json.get("expr", "")
+    # Arbitrary code execution
+    result = eval(expr)
+    return jsonify({"result": result})
