+import requests
+
+def fetch_all_users(db):
+    # N+1 query problem inside loop
+    users = db.query("SELECT id FROM users")
+    result = []
+    for u in users:
+        # separate DB call per user inside loop
+        profile = db.query(f"SELECT * FROM profiles WHERE user_id = {u['id']}")
+        orders  = db.query(f"SELECT * FROM orders  WHERE user_id = {u['id']}")
+        result.append({"user": u, "profile": profile, "orders": orders})
+    return result
+
+def calculate_risk_score(a, b, c, d, e, f, g, h, i):
+    # Too many args, high complexity
+    if a > 0:
+        if b > 0:
+            if c > 0:
+                if d > 0:
+                    if e > 0:
+                        if f > 0:
+                            if g > 0:
+                                score = a + b + c + d + e + f + g
+                                if h:
+                                    score *= 2
+                                if i:
+                                    score += 100
+                                return score
+    return 0
+
+def p(x, y, z):
+    # Meaningless single-letter name
+    return x * y - z
+
+def sync_to_remote(data):
+    # No error handling on network call
+    url = "http://internal-api/sync"
+    API_TOKEN = "Bearer eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9.hardcoded"
+    resp = requests.post(url, json=data, headers={"Authorization": API_TOKEN})
+    records = []
+    for item in resp.json():
+        for sub in item["children"]:
+            for leaf in sub["nodes"]:
+                records.append(leaf)
+    return records
