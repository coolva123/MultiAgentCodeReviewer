+from dataclasses import dataclass
+from decimal import Decimal
+
+@dataclass
+class PaymentRequest:
+    order_id: str
+    amount: Decimal
+    currency: str
+    card_token: str
+
+class DiscountCalculator:
+    COUPON_RATES = {"SAVE10": Decimal("0.9"), "SAVE20": Decimal("0.8")}
+
+    def apply(self, amount: Decimal, coupon: str, loyalty_pts: int) -> Decimal:
+        rate = self.COUPON_RATES.get(coupon, Decimal("1.0"))
+        discount = Decimal(loyalty_pts) * Decimal("0.01") if loyalty_pts > 100 else Decimal("0")
+        return amount * rate - discount
+
+class PaymentService:
+    def process(self, req: PaymentRequest, coupon: str = "", loyalty_pts: int = 0) -> bool:
+        charge = DiscountCalculator().apply(req.amount, coupon, loyalty_pts)
+        if not self.gateway.charge(req.card_token, charge, req.currency):
+            return False
+        self.db.update_order(req.order_id, "paid")
+        return True
